	-rm -f os/macos/$(am__dirstamp)
	-rm -f os/posix/$(DEPDIR)/$(am__dirstamp)
	-rm -f os/posix/$(am__dirstamp)
	-rm -f os/windows/$(DEPDIR)/$(am__dirstamp)
	-rm -f os/windows/$(am__dirstamp)
	-rm -f utils/$(DEPDIR)/$(am__dirstamp)
	-rm -f utils/$(am__dirstamp)
	-rm -f vendored/$(DEPDIR)/$(am__dirstamp)
	-rm -f vendored/$(am__dirstamp)
	-test -z "$(top_builddir)/bin/$(am__dirstamp)" || rm -f $(top_builddir)/bin/$(am__dirstamp)

maintainer-clean-generic:
	@echo "This command is intended for maintainers to use"
	@echo "it deletes files that may require special tools to rebuild."
